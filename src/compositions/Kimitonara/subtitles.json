[
  {
    "text": "誰かを想うたびに",
    "start": 9.4,
    "end": 12.769
  },
  {
    "text": "背中を押す風が吹く",
    "start": 12.769,
    "end": 16.56
  },
  {
    "text": "きっと怖かったんだ",
    "start": 17.72,
    "end": 22.5
  },
  {
    "text": "本音がこぼれるのが",
    "start": 22.6,
    "end": 25.62
  },
  {
    "text": "言葉にすれば",
    "start": 26.86,
    "end": 29.0
  },
  {
    "text": "崩れそうで",
    "start": 29.0,
    "end": 30.789
  },
  {
    "text": "ずっと飲み込んできた",
    "start": 30.789,
    "end": 34.36
  },
  {
    "text": "でも君は笑うから",
    "start": 34.36,
    "end": 38.236
  },
  {
    "text": "不器用なままで",
    "start": 38.236,
    "end": 41.628
  },
  {
    "text": "いたいと思えた",
    "start": 41.628,
    "end": 45.02
  },
  {
    "text": "曖昧でも真っ直ぐでもない",
    "start": 45.02,
    "end": 48.716
  },
  {
    "text": "この距離が",
    "start": 48.716,
    "end": 50.256
  },
  {
    "text": "ちょうどよかった",
    "start": 50.256,
    "end": 52.72
  },
  {
    "text": "君となら全部が",
    "start": 52.72,
    "end": 54.968
  },
  {
    "text": "ちょっとマシに思える",
    "start": 54.968,
    "end": 58.18
  },
  {
    "text": "笑える理由が",
    "start": 58.18,
    "end": 60.66
  },
  {
    "text": "増えてゆく気がしてた",
    "start": 60.66,
    "end": 63.66
  },
  {
    "text": "涙の後さえ",
    "start": 63.66,
    "end": 65.827
  },
  {
    "text": "バカにし合えるような",
    "start": 65.827,
    "end": 70.16
  },
  {
    "text": "そんな時間が",
    "start": 70.96,
    "end": 73.102
  },
  {
    "text": "胸を締め付けた",
    "start": 73.102,
    "end": 78.6
  },
  {
    "text": "忘れようとした日々も",
    "start": 79.64,
    "end": 82.695
  },
  {
    "text": "君がふとよぎるたび",
    "start": 82.695,
    "end": 86.5
  },
  {
    "text": "意味があったような気がして",
    "start": 87.44,
    "end": 92.127
  },
  {
    "text": "また前を向いてた",
    "start": 92.127,
    "end": 95.7
  },
  {
    "text": "名前さえも",
    "start": 97.7,
    "end": 98.743
  },
  {
    "text": "呼べなかった日々",
    "start": 98.743,
    "end": 102.239
  },
  {
    "text": "今じゃ思い出に変わる",
    "start": 102.239,
    "end": 105.1
  },
  {
    "text": "君となら何度でも",
    "start": 105.1,
    "end": 108.209
  },
  {
    "text": "間違えていい",
    "start": 108.209,
    "end": 110.54
  },
  {
    "text": "遠回りだって",
    "start": 110.54,
    "end": 112.777
  },
  {
    "text": "悪くないと思えた",
    "start": 112.777,
    "end": 115.76
  },
  {
    "text": "正解なんてさ",
    "start": 115.76,
    "end": 119.394
  },
  {
    "text": "後から追いついてくる",
    "start": 119.394,
    "end": 122.22
  },
  {
    "text": "そんな風に君が",
    "start": 122.22,
    "end": 125.218
  },
  {
    "text": "変えたんだ",
    "start": 125.218,
    "end": 127.36
  },
  {
    "text": "いつか終わるものなら",
    "start": 127.36,
    "end": 131.023
  },
  {
    "text": "それまで走ればいい",
    "start": 131.023,
    "end": 134.32
  },
  {
    "text": "繋いだ手が解けても",
    "start": 135.28,
    "end": 138.889
  },
  {
    "text": "歩いてたことは消えない",
    "start": 138.889,
    "end": 143.3
  },
  {
    "text": "君となら",
    "start": 145.72,
    "end": 147.246
  },
  {
    "text": "痛みさえも意味になる",
    "start": 147.246,
    "end": 151.06
  },
  {
    "text": "すれ違ったって",
    "start": 151.06,
    "end": 153.5
  },
  {
    "text": "また笑い合えるだろう",
    "start": 153.5,
    "end": 156.74
  },
  {
    "text": "もう逃げないよ",
    "start": 156.74,
    "end": 160.328
  },
  {
    "text": "君を守れるような",
    "start": 160.328,
    "end": 162.72
  },
  {
    "text": "そんな僕で",
    "start": 162.72,
    "end": 165.384
  },
  {
    "text": "ちゃんとありたいんだ",
    "start": 165.384,
    "end": 167.16
  },
  {
    "text": "君とならもう一度",
    "start": 168.32,
    "end": 171.349
  },
  {
    "text": "信じてみたい",
    "start": 171.349,
    "end": 173.62
  },
  {
    "text": "誰でもない君と",
    "start": 173.62,
    "end": 176.506
  },
  {
    "text": "選びたい日々",
    "start": 176.506,
    "end": 178.98
  },
  {
    "text": "風が止んでも",
    "start": 178.98,
    "end": 181.468
  },
  {
    "text": "歩いてゆけるように",
    "start": 181.468,
    "end": 185.2
  },
  {
    "text": "この歌を",
    "start": 185.2,
    "end": 187.484
  },
  {
    "text": "今 届けたい",
    "start": 187.484,
    "end": 190.34
  },
  {
    "text": "君の歌を",
    "start": 218.72,
    "end": 219.431
  },
  {
    "text": "今 届けたい",
    "start": 219.431,
    "end": 220.32
  }
]
